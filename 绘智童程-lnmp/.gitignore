# 绘智童程 LNMP项目 .gitignore

# 系统文件
.DS_Store
Thumbs.db
Desktop.ini
*.swp
*.swo
*~

# IDE文件
.idea/
.vscode/
*.sublime-project
*.sublime-workspace

# 日志文件
/storage/logs/*.log

# 缓存文件
/storage/cache/*

# 上传文件（保留目录结构）
/public/uploads/*
!/public/uploads/.gitkeep

# 环境配置文件
.env
.env.local
.env.production

# Composer依赖
/vendor/
composer.lock

# Node依赖
/node_modules/
package-lock.json

# 临时文件
*.tmp
*.temp
*.bak
*.backup

# 数据库备份
*.sql.bak
*.sql.gz

# 敏感信息
config.local.php
*.key
*.pem

# 编辑器配置
*.swp
*.swo
.vscode/
.idea/

# 系统缓存
*.cache
*.log